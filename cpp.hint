#define DEFINE_PROPERTY(Type, Name, DefaultValue) protected: Type m_##Name = DefaultValue; public: Type Get##Name() const { return m_##Name; } virtual void Set##Name(const Type& val) { if (IsDifferent(m_##Name, val)) { m_##Name = val; } } __declspec(property(get = Get##Name, put = Set##Name)) Type Name;
#define DEFINE_PROPERTY_WITH_EVENТ(Type, Name, DefaultValue) protected: Type m_##Name = DefaultValue; public: Type Get##Name() const { return m_##Name; } virtual void Set##Name(const Type& val) { if (IsDifferent(m_##Name, val)) { m_##Name = val; Name##Changed(val); } } __declspec(property(get = Get##Name, put = Set##Name)) Type Name; Event<Type> Name##Changed;
